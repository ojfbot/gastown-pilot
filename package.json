{
  "name": "gastown-pilot",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev:all": "concurrently -n api,app -c blue,green \"pnpm --filter @ojfbot/gastown-pilot-api dev\" \"pnpm --filter @ojfbot/gastown-pilot-browser-app dev\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
